% Color Palette
% From https://brand.gatech.edu/our-look/colors

% Primary
\definecolor{GTGold}{RGB}{179, 163, 105}
\definecolor{GTNavy}{RGB}{0, 48, 87}
\definecolor{GTWhite}{RGB}{255, 255, 255}
\definecolor{GTBlack}{RGB}{0, 0, 0}

% Secondary
\definecolor{GTGray}{RGB}{84, 88, 90}
\definecolor{GTMile}{RGB}{214, 219, 212}
\definecolor{GTDiploma}{RGB}{249, 246, 229}
\definecolor{GTBuzzGold}{RGB}{234, 170, 0}

% Tertiary
\definecolor{GTBrightPurple}{RGB}{120, 0, 255}
\definecolor{GTBrightElectric}{RGB}{0, 255, 255}
\definecolor{GTBrightBuzz}{RGB}{255, 204, 0}
\definecolor{GTBrightBlue}{RGB}{41, 97, 255}
\definecolor{GTBrightCanopy}{RGB}{0, 236, 156}
\definecolor{GTBrightHorizon}{RGB}{255, 100, 15}

% ====================
% Theme
% ====================

% Basic colors
\setbeamercolor{palette primary}{fg=GTBlack,bg=GTWhite}
\setbeamercolor{palette secondary}{fg=GTBlack,bg=GTWhite}
\setbeamercolor{palette tertiary}{bg=GTBlack,fg=GTWhite}
\setbeamercolor{palette quaternary}{fg=GTBlack,bg=GTWhite}
\setbeamercolor{structure}{fg=violet}

% Headline
\setbeamercolor{headline}{fg=GTNavy,bg=GTGold}
\setbeamercolor{headline rule}{bg=GTNavy}

% Block
\setbeamercolor{block title}{fg=GTNavy,bg=GTWhite}
\setbeamercolor{block separator}{bg=GTBlack}
\setbeamercolor{block body}{fg=GTBlack,bg=GTWhite}

% Alert Block
\setbeamercolor{block alerted title}{fg=GTNavy,bg=GTMile}
\setbeamercolor{block alerted separator}{bg=GTBlack}
\setbeamercolor{block alerted body}{fg=GTBlack,bg=GTMile}

% Heading
\setbeamercolor{heading}{fg=GTBlack}

% Itemize
\setbeamercolor{item}{fg=GTGray}

% Bibliography
\setbeamercolor{bibliography item}{fg=GTBlack}
\setbeamercolor{bibliography entry author}{fg=GTBlack}
\setbeamercolor{bibliography entry title}{fg=GTBlack}
\setbeamercolor{bibliography entry location}{fg=GTBlack}
\setbeamercolor{bibliography entry note}{fg=GTBlack}
\setbeamertemplate{bibliography entry article}{}
\setbeamertemplate{bibliography entry title}{}
\setbeamertemplate{bibliography entry location}{}
\setbeamertemplate{bibliography entry note}{}
